{
  "manifest_version": 3,
  "name": "OpenRouter Dashboard",
  "version": "1.0.0",
  "description": "Real-time OpenRouter API usage dashboard",
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://openrouter.ai/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
